# Copy to .env and fill in. Never commit .env — it is gitignored.

# Triage, scoring, and synthesis. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Raises the GitHub API rate limit from 60 to 5,000 req/hr.
# A fine-grained token with PUBLIC READ-ONLY access is sufficient — SignalForge
# only reads releases and tags from public repos. Grant nothing else.
GITHUB_TOKEN=
